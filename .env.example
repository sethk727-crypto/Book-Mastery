NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — used by /api/books/extract. Never expose with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comprehension quizzes (server-only). Set EITHER key — OpenAI is preferred
# when both are present. Both are pay-per-use APIs (a quiz costs well under
# a cent on gpt-4o-mini; a few cents on Claude).
OPENAI_API_KEY=
# OPENAI_QUIZ_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# Push reminders. Generate a pair by visiting /api/notifications/keys once.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
